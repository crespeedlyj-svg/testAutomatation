# ================================================================
# 행정정보시스템 E2E 테스트 환경변수
# ================================================================
# 이 파일을 복사하여 .env 파일을 만들고 실제 값을 입력하세요:
#   cp .env.example .env
#
# .env 파일은 .gitignore에 의해 Git에 커밋되지 않습니다.
# ================================================================

# ---------------------------------------------------------------
# 서버 URL
# ---------------------------------------------------------------
APP_BASE_URL=http://127.0.0.1:8088

# ---------------------------------------------------------------
# 앱 컨텍스트 경로 (nxui 인덱스 URL의 앱 이름 부분)
# 예: http://localhost:8088/nxui/{APP_CONTEXT_PATH}/index.jsp
# ---------------------------------------------------------------
APP_CONTEXT_PATH=gprooneis

# ---------------------------------------------------------------
# 로그인 URL (testLogin.jsp 방식)
# 비밀번호 없이 사용자 목록에서 선택하는 테스트 로그인 페이지
# ---------------------------------------------------------------
APP_LOGIN_URL=http://127.0.0.1:8088/testLogin.do

# ---------------------------------------------------------------
# 로그인할 사용자 검색어
# testLogin.do 검색 폼의 [사용자] 필드(SCH_USER_NM)에 입력할 값
# 예: 홍길동, 홍 (부분 검색 가능)
# ---------------------------------------------------------------
APP_SEARCH_USER_NM=홍길동

# ---------------------------------------------------------------
# 시스템 선택 (라디오 버튼)
# auth.setup.ts 가 내부적으로 "M_" 접두어를 붙이므로
# 여기서는 접두어 없이 시스템 코드만 입력
# MIS : MIS 시스템 (기본값)
# PMS : PMS 시스템
# IPS : IPS 시스템
# EMS : EMS 시스템
# ---------------------------------------------------------------
APP_SYSTEM_ID=MIS

# ---------------------------------------------------------------
# TC014 신규 저장 — pur_5115M 신규 건 저장 테스트용 코드
#
# fn_getDlvrPlcCd() 호출로 납품장소를 자동 설정 시도하나,
# 이전 신청 기록이 없거나 BUDG_BSNS_NM/ACCT_CD 코드가 필요한 경우
# 아래 환경변수를 실제 유효한 값으로 설정하세요.
#
# 미설정 시 fallback 테스트값 사용 → 서버 거부로 MRO_RQST_NO 미발급 가능
# ---------------------------------------------------------------
# 납품장소 코드 (fac_0999P 팝업 결과: DHRM_CD)
APP_TEST_DLVR_PLC_CD=
# 납품장소 건물명 (BLDG_NM)
APP_TEST_DLVR_PLC=
# 실수령장소 주소 (배송지 상세주소)
APP_TEST_DLVY_ADDR=
# 예산명 (BUDG_BSNS_NM)
APP_TEST_BUDG_BSNS_NM=
# 예산코드 (BUDG_BSNS_CD)
APP_TEST_BUDG_BSNS_CD=
# 예산연도 (BUDG_YY, 기본값: 현재년도)
APP_TEST_BUDG_YY=
# 계정코드 (ACCT_CD)
APP_TEST_ACCT_CD=
# 계정명 (ACCT_NM)
APP_TEST_ACCT_NM=

# ---------------------------------------------------------------
# XFDL 테스트 자동화 도구 포트 (tools/server.js)
# Spring MVC(8088)와 다른 포트 사용
# ---------------------------------------------------------------
TOOL_PORT=8090
